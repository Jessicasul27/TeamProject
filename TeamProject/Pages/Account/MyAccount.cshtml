@page 
@model TeamProject.Pages.Account.MyAccountModel
@using Microsoft.AspNetCore.Identity
@using TeamProject.Models.Models
@inject SignInManager<User> signInManager
@{
}

<div class="">
    <div class="container backgroundWhite">
        <div class="card">
            <div class="card-header">
                <div class="text-light ml-0 row ">
                    <div class="col-12 col-md-6 pt-2  ">
                        <h1 class="text-primary ">Account Details</h1>
                    </div>
                </div>
            </div>

            <div class="card-body">
                <div class="container rounded p-2">

                    <div class="row">
                        <div class="col-12 col-lg-8">

                         

                            <p>First Name: @Model.MyUser.FirstName </p>
                            <p>Last Name:  @Model.MyUser.LastName</p>
                            <p>Username:   @Model.MyUser.UserName</p>
                            <p>Email Address:   @Model.MyUser.Email</p>


                        </div>
                    </div>

                    <hr/>

                  

                        <div class="card-footer mt-3">
                            <div class="row">

                                <div class="col-12 col-md-6 pb-1">
                                    <a asp-page="Account/MyBooking"
                                       class="btn btn-success form-control"
                                   style="height:50px; border-radius: 10px;">
                                        Check my Booking
                                    </a>
                                </div>
                            <div class="col-12 col-md-6 pb-1">
                                <a asp-page="/Index"
                                   class="btn btn-primary form-control"
                                   style="height:50px; border-radius: 10px;">
                                    Back To Home
                                </a>
                            </div>

                            </div>
                        </div>
            


                </div>
            </div>

        </div>
    </div>
</div>
