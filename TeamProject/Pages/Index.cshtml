@page "{SearchString?}"
@model TeamProject.Pages.IndexModel
@{
    ViewData["HideHeader"] = true;
}

<header
    class="tw:tracking-normal tw:grid tw:grid-cols-[1fr_auto_1fr] tw:items-center tw:py-8 tw:px-12 tw:bg-neutral-50 tw:border-b-2 tw:border-neutral-200">

    @* Home *@
    <a class="tw:no-underline! tw:uppercase tw:font-bold tw:text-3xl" asp-page="/">Staycraft</a>

    @* Where, When, Who *@
    <div
        class="tw:flex tw:items-center tw:border tw:bg-white tw:border-neutral-300 tw:rounded-full tw:text-sm tw:font-semibold tw:text-black tw:shadow-lg">

        <div
            class="tw:flex tw:flex-col tw:rounded-l-full tw:w-70 tw:px-8 tw:py-4 tw:cursor-pointer tw:hover:bg-neutral-200">
            <span>Where</span>
            <input placeholder="Search destinations" type="text"/>
        </div>

        <div class="tw:w-px tw:self-stretch tw:bg-neutral-300"></div>

        <div class="tw:flex tw:flex-col tw:w-70 tw:px-8 tw:py-4 tw:cursor-pointer tw:hover:bg-neutral-200">
            <span>When</span>
            <span class="text-muted">Add dates</span>
        </div>

        <div class="tw:w-px tw:self-stretch tw:bg-neutral-300"></div>

        <div
            class="tw:flex tw:justify-between tw:items-center tw:rounded-r-full tw:w-70 tw:pl-8  tw:cursor-pointer tw:[&:hover:not(:has(button:hover))]:bg-neutral-200">
            <div class="tw:flex tw:flex-col tw:py-4">
                <span>Who</span>
                <span class="text-muted">Add guests</span>
            </div>
            <button
                type="button"
                class="tw:flex tw:items-center tw:justify-center tw:w-14 tw:h-14 tw:bg-green-900 tw:text-white tw:rounded-full! tw:mr-2!">
                <i data-lucide="search" class="tw:w-[40%] tw:h-[40%]"></i>
            </button>
        </div>
    </div>

    @* Login, dropdown (the cart/reservation thing) *@
    <div class="tw:justify-self-end">
        <a asp-page="/Login">Login</a>
        @* ... *@
    </div>
</header>

<div class="container backgroundWhite tw:py-3">
    @* <p> *@
    @* <form class="d-flex"> *@
    @*     <input type="text" placeholder="Enter Location of property you would like to view..." *@
    @*            class="form-control me-sm-2" asp-for="SearchString"/> *@
    @*     <input type="submit" value="Search" class="btn btn-outline"/> *@
    @*     <a asp-rote-Products="" asp-route-SearchString="" class="btn btn-outline-secondary ms-2">Clear</a> *@
    @* </form> *@
    @* </p> *@

    @foreach (var propertyType in Model.listOfProperties.GroupBy(p => p.PropertyType))
    {
        <h2 class="text-success pl-1">
            <b>@propertyType.Key</b>
        </h2>

        <div class="row">
            @foreach (var property in propertyType)
            {
                <div class="col-lg-4 col-md-6 pb-4 filter">
                    <div class="card bg-white rounded shadow-sm" style="border: 1px solid #222">

                        <div class="card-body pb-1 row">
                            <div
                                class="col-8 h5 tw:min-h-10 tw:line-clamp-2">@property.Title</div>
                            <div class="col-4 text-end">
                                <span class="text-info h4">
                                    €@property.PricePerNight
                                </span>
                            </div>
                        </div>

                        <img class="card-img-top img-fluid d-block mx-auto mb-3"
                             src="@property.DisplayImage"
                             alt="menuitem image">

                        <div class="card-body p-1 px-3 row">
                            <div class="col-6">
                                <span class="badge p-2 border w-100 text-dark bg-warning">
                                    @property.PropertyType
                                </span>
                            </div>

                            <div class="col-6 border-0">
                                <span class="badge p-2 border w-100 bg-info">
                                    @property.Title
                                </span>
                            </div>

                            <div class="col-12 pt-2" style="font-size:13px; text-align:justify">
                                <p>@property.DescDescription</p>
                            </div>

                            <div class="col-12 p-1">
                                <a asp-page="/Customers/Home/Details"
                                   asp-route-id="@property.Id"
                                   class="btn btn-dark form-control btn-sm p-2"
                                   style="height: 40px">
                                    View Details
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>