@page
@model TeamProject.Pages.Admin.Customers.DeleteModel
@{
}

<form method="post">
    <input hidden asp-for="Customer.UserId"/>

    <div class="border p-3 mt-4">
        <div class="row pb-2">
            <h2 class="text-primary pl-3">Delete Customer</h2>
        </div>

        <div class="mb-3">
            <label asp-for="@Model.Customer.User.FirstName"></label>
            <input asp-for="@Model.Customer.User.FirstName" class="form-control" readonly/>
            <span asp-validation-for="@Model.Customer.User.FirstName" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="@Model.Customer.User.LastName"></label>
            <input asp-for="@Model.Customer.User.LastName" class="form-control" readonly/>
            <span asp-validation-for="@Model.Customer.User.LastName" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="@Model.Customer.User.Email"></label>
            <input asp-for="@Model.Customer.User.Email" class="form-control" readonly/>
            <span asp-validation-for="@Model.Customer.User.Email" class="text-danger"></span>
        </div>

        <button type="submit" class="btn btn-primary">Delete</button>

        <a asp-page="Index" class="btn btn-primary">Back to index</a>
    </div>
</form>

@section Scripts {
    @{
        <partial name="_validationScriptsPartial"/>
    }
}