@page
@model TeamProject.Pages.Admin.Customers.CreateModel
@{
}

<form method="post">
    <div class="border p-3 mt-4">
        <div class="row pb-2">
            <h2 class="text-primary pl-3">Enter Customer Details</h2>
        </div>
        <div class="mb-3">
            <label asp-for="@Model.Customer.Name"></label>
            <input asp-for="@Model.Customer.Name" class="form-control"/>
            <span asp-validation-for="@Model.Customer.Name" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="@Model.Customer.Email"></label>
            <input asp-for="@Model.Customer.Email" class="form-control"/>
            <span asp-validation-for="@Model.Customer.Email" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="@Model.Customer.PhoneNumber"></label>
            <input asp-for="@Model.Customer.PhoneNumber" class="form-control" />
            <span asp-validation-for="@Model.Customer.PhoneNumber" class="text-danger"></span>
        </div>

        @* <div class="mb-3">
            <label asp-for="@Model.Customer.CreditCardNo"></label>
            <input asp-for="@Model.Customer.CreditCardNo" class="form-control" />
            <span asp-validation-for="@Model.Customer.CreditCardNo" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="@Model.Customer.CVC"></label>
            <input asp-for="@Model.Customer.CVC" class="form-control" />
            <span asp-validation-for="@Model.Customer.CVC" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="@Model.Customer.ExpiryDate"></label>
            <input asp-for="@Model.Customer.ExpiryDate" class="form-control" />
            <span asp-validation-for="@Model.Customer.ExpiryDate" class="text-danger"></span>
        </div> *@

        <button type="submit" class="btn btn-primary">Submit</button>
    </div>
</form>
@section Scripts {
    @{
        <partial name="_validationScriptsPartial" />
    }
}