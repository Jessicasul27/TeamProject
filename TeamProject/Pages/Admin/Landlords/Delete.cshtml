@page
@model DeleteModel
@{
}

<form method="post">
    <div class="border p-3 mt-4">
        <div class="row pb-2">
            <h2 class="text-primary pl-3">Landlords Details</h2>
        </div>

        <input type="hidden" asp-for="Landlords.UserId"/>

        <div class="mb-3">
            <label asp-for="@Model.Landlords.User.FirstName"></label>
            <input asp-for="@Model.Landlords.User.FirstName" class="form-control"/>
            <span asp-validation-for="@Model.Landlords.User.FirstName" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="@Model.Landlords.User.LastName"></label>
            <input asp-for="@Model.Landlords.User.LastName" class="form-control"/>
            <span asp-validation-for="@Model.Landlords.User.LastName" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="@Model.Landlords.User.Email"></label>
            <input asp-for="@Model.Landlords.User.Email" class="form-control"/>
            <span asp-validation-for="@Model.Landlords.User.Email" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="@Model.Landlords.User.PhoneNumber"></label>
            <input asp-for="@Model.Landlords.User.PhoneNumber" class="form-control"/>
            <span asp-validation-for="@Model.Landlords.User.PhoneNumber" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="@Model.Landlords.LandlordShare"></label>
            <input asp-for="@Model.Landlords.LandlordShare" class="form-control"/>
            <span asp-validation-for="@Model.Landlords.LandlordShare" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="@Model.Landlords.Income"></label>
            <input asp-for="@Model.Landlords.Income" class="form-control"/>
            <span asp-validation-for="@Model.Landlords.Income" class="text-danger"></span>
        </div>

        <button type="submit" class="btn btn-primary">Delete</button>
    </div>
</form>

@section Scripts {
    @{
        <partial name="_validationScriptsPartial"/>
    }
}