@page
@model IndexModel
@{
}

<style>
    .table-btn {
        display: inline-block;
        min-width: 70px;
        padding: 4px 8px;
        font-size: 0.85rem;
        text-align: center;
        text-decoration: none;
        color: #ffffff;
    }
</style>

<div class="container p-3">
    <div class="row pt-4 mb-3">
        <div class="col-6">
            <h3 class="text-primary">Property</h3>
        </div>
        <div class="col-6 text-end">
            <a asp-page="Create" class="btn btn-primary">
                Create New Property
            </a>
        </div>
    </div>

    <table class="table table-bordered table-striped">
        <thead>
        <tr>
            <th>Name</th>
            <th>Location</th>
            <th>Property Type</th>
            <th>Price Per Night</th>
            <th>Max Guests</th>
            <th>Status</th>
            <th>Actions</th>
        </tr>
        </thead>
        <tbody>
        @foreach (var obj in Model.Properties)
        {
            <tr>
                <td>@obj.Title</td>
                <td>@obj.Location</td>
                <td>@obj.PropertyType</td>
                <td>€@obj.PricePerNight</td>
                <td>@obj.MaxGuests</td>
                <td>@obj.Status</td>
                <td>
                    <a asp-page="Edit" asp-route-id="@obj.Id" class="btn btn-success btn-sm mx-1">Edit</a>
                    <a asp-page="Delete" asp-route-id="@obj.Id" class="btn btn-danger btn-sm mx-1">Delete</a>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>

@section Scripts {
    @{
        <partial name="_validationScriptsPartial"/>
    }
}