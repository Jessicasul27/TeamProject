@page
@model TeamProject.Pages.Admin.Properties.DeleteModel
@{
}

<form method="post" enctype="multipart/form-data">
    <input hidden asp-for="Property.Id"/>
    <div class="border p-3 mt-4">
        <div class="row pb-2">
            <h2 class="text-primary pl-3">Delete Property</h2>
        </div>

        <div class="border p-3 mt-4">
            <div class="mb-3">
                <label asp-for="@Model.Property.Title"></label>
                <input asp-for="@Model.Property.Title" class="form-control" readonly/>
                <span asp-validation-for="@Model.Property.Title" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="@Model.Property.Location"></label>
                <input asp-for="@Model.Property.Location" class="form-control" readonly/>
                <span asp-validation-for="@Model.Property.Location" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="@Model.Property.PropertyType"></label>
                <input asp-for="@Model.Property.PropertyType" class="form-control" readonly/>
                <span asp-validation-for="@Model.Property.PropertyType" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="@Model.Property.PricePerNight"></label>
                <input asp-for="@Model.Property.PricePerNight" class="form-control" readonly/>
                <span asp-validation-for="@Model.Property.PricePerNight" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Property.Status" class="form-label"></label>
                <input asp-for="Property.Status" class="form-select" readonly>
                </input>
                <span asp-validation-for="Property.Status" class="text-danger"></span>
            </div>
            <div>
                <label asp-for="@Model.Property.FullDescription"></label>
                <textarea asp-for="@Model.Property.FullDescription" class="form-control" readonly></textarea>
                <span asp-validation-for="@Model.Property.FullDescription" class="text-danger"></span>
            </div>
            <div>
                <label asp-for="@Model.Property.DescDescription"></label>
                <textarea asp-for="@Model.Property.DescDescription" class="form-control" readonly></textarea>
                <span asp-validation-for="@Model.Property.DescDescription" class="text-danger"></span>
            </div>
            <div>
                <label asp-for="@Model.Property.MaxGuests"></label>
                <input asp-for="@Model.Property.MaxGuests" class="form-control" readonly/>
                <span asp-validation-for="@Model.Property.MaxGuests" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label>Display Image</label><br/>
                <img src="@Model.Property.DisplayImage" width="200" class="mb-2"/>
            </div>

        </div>
        
        
        <div class="mb-3">
                <label>Gallery Images</label><br/>

            @if (Model.Property.Images != null)
            {
                foreach (var img in Model.Property.Images)
                {
                                <div style="display:inline-block; margin:10px;">
                                    <img src="@img.ImageUrl" width="150"/><br/>


                                </div>
                }
            }
            </div>
        <div class="mb-3">
            <button type="submit" class="btn btn-danger">Delete</button>
            <a asp-page="Index" class="btn btn-primary">Back to Index</a>
        </div>
    </div>
</form>
@section Scripts {
    @{
                <partial name="_validationScriptsPartial"/>
    }
}
