@page
@using TeamProject.Models.Models
@model EditModel
@{
}

<form method="post" enctype="multipart/form-data">
    <input hidden asp-for="Property.Id"/>
    <div class="border p-3 mt-4">
        <div class="row pb-2">
            <h2 class="text-primary pl-3">Edit Property</h2>
        </div>

        <div class="border p-3 mt-4">
            <div class="mb-3">
                <label asp-for="@Model.Property.Title"></label>
                <input asp-for="@Model.Property.Title" class="form-control"/>
                <span asp-validation-for="@Model.Property.Title" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="@Model.Property.Location"></label>
                <input asp-for="@Model.Property.Location" class="form-control"/>
                <span asp-validation-for="@Model.Property.Location" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="@Model.Property.PropertyType"></label>
                <select asp-for="Property.PropertyType" asp-items="Html.GetEnumSelectList<PropertyType>()"
                        class="form-select">
                </select>
                <span asp-validation-for="@Model.Property.PropertyType" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="@Model.Property.PricePerNight"></label>
                <input asp-for="@Model.Property.PricePerNight" class="form-control"/>
                <span asp-validation-for="@Model.Property.PricePerNight" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Property.Status" class="form-label"></label>
                <select asp-for="Property.Status" asp-items="Html.GetEnumSelectList<PropertyStatus>()"
                        class="form-select">
                </select>
                <span asp-validation-for="Property.Status" class="text-danger"></span>
            </div>
            <div>
                <label asp-for="@Model.Property.FullDescription"></label>
                <textarea asp-for="@Model.Property.FullDescription" class="form-control"></textarea>
                <span asp-validation-for="@Model.Property.FullDescription" class="text-danger"></span>
            </div>
            <div>
                <label asp-for="@Model.Property.DescDescription"></label>
                <textarea asp-for="@Model.Property.DescDescription" class="form-control"></textarea>
                <span asp-validation-for="@Model.Property.DescDescription" class="text-danger"></span>
            </div>
            <div>
                <label asp-for="@Model.Property.MaxGuests"></label>
                <input asp-for="@Model.Property.MaxGuests" class="form-control"/>
                <span asp-validation-for="@Model.Property.MaxGuests" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label>Current Display Image</label><br/>
                <img src="@Model.Property.DisplayImage" width="200" class="mb-2"/>
            </div>

            <div class="mb-3">
                <label>Replace Display Image</label>
                <input type="file" name="displayFile" class="form-control"/>
            </div>


            <div class="mb-3">
                <label>Gallery Images</label><br/>

                @if (Model.Property.Images != null)
                {
                    foreach (var img in Model.Property.Images)
                    {
                        <div style="display:inline-block; margin:10px;">
                            <img src="@img.ImageUrl" width="150"/><br/>


                            <button type="submit"
                                    formaction="?handler=DeleteImage"
                                    formmethod="post"
                                    name="imageId"
                                    value="@img.Id"
                                    class="btn btn-danger btn-sm mt-1">
                                Delete
                            </button>
                        </div>
                    }
                }
            </div>


            <div class="mb-3">
                <label>Add More Images</label>
                <input type="file" name="galleryFiles" multiple class="form-control"/>
            </div>

            <div class="mb-3">
                <button type="submit" class="btn btn-success">Update</button>
                <a asp-page="Index" class="btn btn-primary">Back to Index</a>
            </div>
        </div>
    </div>
</form>

